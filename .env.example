# Database (Required)
# Neon PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Authentication (Required)
# Auth.js v5 secret key - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Auth.js v5 URL (production)
NEXTAUTH_URL="http://localhost:3000"

# Rate Limiting (Optional - for serverless production)
# Get free Redis at https://upstash.com
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# Optional: Redis for caching
REDIS_URL="redis://localhost:6379"

# Vercel specific (auto-populated in Vercel)
VERCEL_URL=""

# Optional error webhook
WEBHOOK_ERROR_URL=""

# Node Environment
NODE_ENV="development"

# AI Services
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
PERPLEXITY_API_KEY=

# Card Data APIs
RAPID_API_KEY=
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_ENVIRONMENT=production
